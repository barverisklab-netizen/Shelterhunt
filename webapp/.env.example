# Mapbox (placeholder only; do not commit real keys)
VITE_DEPLOYED_CITY_ID=koto
# Optional: comma-separated subset override of city-supported locales
# Must be a subset of locales declared in city layers.ts
# Example: en,ja
VITE_SUPPORTED_LOCALES=
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here
VITE_MAPBOX_USERNAME=your-mapbox-username
VITE_MAPBOX_STYLE_URL=

# API endpoints (local defaults)
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_BASE_URL=ws://localhost:4000

# Localization
VITE_DEFAULT_LOCALE=en

# Gameplay timing / range
VITE_LIGHTNING_MINUTES=30
VITE_LIGHTNING_RADIUS_KM=2
VITE_MULTIPLAYER_RADIUS_KM=2

# Legacy key kept for compatibility with older local files (runtime uses VITE_LIGHTNING_MINUTES)
VITE_LIGHTNING_DURATION_MINUTES=30

# Set to true to bypass proximity gating for local testing
VITE_ENABLE_PROXIMITY=false

# Radius (km) for proximity gating and nearby amenity counts
VITE_PROXIMITY_RADIUS_KM=0.25

# Set to true to apply timer penalties on wrong guesses (legacy behavior)
VITE_ENABLE_WRONG_GUESS_PENALTY=false

# Set to true to allow only one asked question per location; players must move before asking again
VITE_ONE_QUESTION_PER_LOCATION=false

# Dev only - set true to log missing locale keys in console
VITE_I18N_DEBUG=true
