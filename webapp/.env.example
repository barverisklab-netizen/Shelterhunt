# Production env (if you deploy with Vite and want a different token)
VITE_MAPBOX_TOKEN=pk.your_production_mapbox_token_here
VITE_MAPBOX_USERNAME=your-mapbox-username-here
VITE_MAPBOX_STYLE_URL=
VITE_LIGHTNING_DURATION_MINUTES=30
VITE_LIGHTNING_RADIUS_KM=2
VITE_API_BASE_URL=http://localhost:4000
VITE_DEFAULT_LOCALE=en
# Set to true to bypass proximity for local testing
VITE_ENABLE_PROXIMITY=false
# Radius (km) for proximity gating and nearby amenity counts
VITE_PROXIMITY_RADIUS_KM=0.25
# Set to true to apply timer penalties on wrong guesses (legacy behavior)
VITE_ENABLE_WRONG_GUESS_PENALTY=false
# Set to true to allow only one asked question per location; players must move before asking again
VITE_ONE_QUESTION_PER_LOCATION=false
# dev only - set true to see missing locales keys in console
VITE_I18N_DEBUG=true
