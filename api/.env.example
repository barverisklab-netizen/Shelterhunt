TASKS_CRON_SECRET=replace-with-long-random-cron-secret

# Use any PostgreSQL-compatible provider. Keep credentials out of git.
# Hosted Postgres example (TLS required):
DATABASE_URL=postgresql://user:password@db.example.com:5432/shelterhunt?sslmode=require
# Local Postgres example (no TLS): postgresql://postgres:postgres@localhost:5432/shelterhunt?sslmode=disable
DB_SCHEMA=public
DEPLOYED_CITY_ID=tokyo-23

NODE_ENV=development
PORT=4000
JWT_SECRET=super-secret-change-me
DB_SSL_ALLOW_SELF_SIGNED=false
DB_CONNECT_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=10000
SESSION_TTL_MINUTES=20
SESSION_MAX_PLAYERS=8
SESSION_MAX_DISTANCE_KM=2

# Webapp dev server default from webapp/vite.config.ts
CORS_ORIGIN=http://localhost:5000

# Default local dataset location in this repo
SHELTER_DATA_PATH=../data/geojson/ihi_shelters.geojson
