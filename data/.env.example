# Hosted Postgres/Supabase (recommended): enforce verified TLS.
DATABASE_URL=postgresql://user:password@db.example.com:5432/dbname?sslmode=require
# Local Postgres only (no TLS): postgresql://postgres:postgres@localhost:5432/shelterhunt?sslmode=disable
SHELTER_DATA_PATH=geojson/ihi_shelters.geojson
DATA_API_BASE_URL=http://localhost:4000
OUTPUT_PATH=geojson/ihi_shelters.geojson
